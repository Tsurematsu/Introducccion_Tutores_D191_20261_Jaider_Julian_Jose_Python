# ─── Variables de entorno — EduTutor ─────────────────────────────────────────
#
# Copia este archivo como .env.local (git-ignorado) y rellena los valores.
# En Vercel: Settings → Environment Variables (usa los mismos nombres).
#
# ─── Base de datos ────────────────────────────────────────────────────────────
#
# Opción A — cadena de conexión única (Neon, Supabase, Railway, etc.):
POSTGRES_URL=postgresql://usuario:contraseña@host:5432/nombre_db?sslmode=require

# Opción B — variables individuales (descomentar si no usas POSTGRES_URL):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=edututor
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=mi_contraseña
# POSTGRES_SSL=false    # ← "false" para desarrollo local sin SSL

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria

# ─── Entorno ──────────────────────────────────────────────────────────────────
# NODE_ENV=development
